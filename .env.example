# DayFlow — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit your actual .env file — it is excluded by .gitignore.

# ---------------------------------------------------------------
# Required
# ---------------------------------------------------------------

# OpenAI API key — used for natural language schedule parsing
# Get yours at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://user:password@localhost:5432/dayflow

# Secret used for session signing — use a long random string
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=your-random-secret-here

# ---------------------------------------------------------------
# Optional
# ---------------------------------------------------------------

# Port for the Express backend (default: 5000)
PORT=5000
